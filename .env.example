# ─── AI Provider ─────────────────────────────────────────────────────────────
# The provider uses a single OpenAI-compatible endpoint.
# Set BASE_URL, API_KEY, and MODEL below for your chosen provider.
#
# Examples:
#   OpenAI        → BASE_URL=https://api.openai.com/v1
#   Anthropic     → (not supported — OpenAI-compatible only)
#   Ollama        → BASE_URL=http://localhost:11434/v1
#   LM Studio     → BASE_URL=http://localhost:1234/v1
#   Together      → BASE_URL=https://api.together.xyz/v1
#   Groq          → BASE_URL=https://api.groq.com/openai/v1
#   vLLM          → BASE_URL=http://localhost:8000/v1

# Required: base URL for the OpenAI-compatible API
BASE_URL=https://api.openai.com/v1

# Required: API key (use 'none' for local servers that don't require one)
API_KEY=sk-...

# Required: model name
MODEL=gpt-4o

# Optional: set to 'true' if your model supports vision (image inputs)
SUPPORTS_VISION=true

# ─── Display Name (optional) ─────────────────────────────────────────────────
# Used in the TUI header — purely cosmetic, not read by the provider
AI_PROVIDER=openai

# ─── Edge Profile ─────────────────────────────────────────────────────────────
# Run `node scripts/setup.js` to auto-detect your profiles
# Or set manually:
EDGE_PROFILE_DIR=Profile 11
# (Profile 12 in Edge UI = "Profile 11" folder, Default = first profile)

# Custom Edge user data directory (leave blank for default Mac location)
# EDGE_USER_DATA_DIR=/Users/yourname/Library/Application Support/Microsoft Edge

# ─── Behavior ─────────────────────────────────────────────────────────────────
# Show browser window (true) or run headless (false)
HEADLESS=false

# Max steps the agent can take per task (safety limit)
MAX_AGENT_STEPS=50

# Highlight elements before interacting (visual feedback)
HIGHLIGHT_ELEMENTS=true
