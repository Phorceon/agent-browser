# ─── AI Provider ────────────────────────────────────────────────────────────
# The provider uses a single OpenAI-compatible endpoint.
# Set BASE_URL, API_KEY, and MODEL below.
# Works with any OpenAI-compatible service:
#   OpenAI, Anthropic (via proxy), Google, Ollama, LM Studio, vLLM, Together, Groq, etc.

# OpenAI example:
#   BASE_URL=https://api.openai.com/v1
#   API_KEY=sk-...
#   MODEL=gpt-4o
#
# Ollama (local, no key needed):
#   BASE_URL=http://localhost:11434/v1
#   API_KEY=none
#   MODEL=llama3.2
#
# LM Studio / vLLM / other local:
#   BASE_URL=http://localhost:1234/v1
#   API_KEY=lm-studio
#   MODEL=local-model
#
# Anthropic Claude (requires an OpenAI-compatible proxy like LiteLLM):
#   BASE_URL=http://localhost:4000/v1
#   API_KEY=sk-ant-...
#   MODEL=claude-3-5-sonnet-20241022
#
# Google Gemini (requires an OpenAI-compatible proxy like LiteLLM):
#   BASE_URL=http://localhost:4000/v1
#   API_KEY=AIza...
#   MODEL=gemini-2.0-flash-exp

BASE_URL=https://api.openai.com/v1
API_KEY=sk-...
MODEL=gpt-4o

# Set to "true" if the model supports vision (image inputs)
SUPPORTS_VISION=true

# ─── Active Provider Label ───────────────────────────────────────────────────
# Display-only label shown in the TUI header (does not affect provider selection)
AI_PROVIDER=openai

# ─── Edge Profile ───────────────────────────────────────────────────────────
# Run `node scripts/setup.js` to auto-detect your profiles
# Or set manually:
EDGE_PROFILE_DIR=Profile 11
# (Profile 12 in Edge UI = "Profile 11" folder, Default = first profile)

# Custom Edge user data directory (leave blank for default Mac location)
# EDGE_USER_DATA_DIR=/Users/yourname/Library/Application Support/Microsoft Edge

# ─── Behavior ────────────────────────────────────────────────────────────────
# Show browser window (true) or run headless (false)
HEADLESS=false

# Max steps the agent can take per task (safety limit)
MAX_AGENT_STEPS=50

# Highlight elements before interacting (visual feedback)
HIGHLIGHT_ELEMENTS=true
