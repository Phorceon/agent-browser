# ─── AI Provider ──────────────────────────────────────────────────────────────
# The provider uses a single OpenAI-compatible endpoint (src/providers/index.js).
# Set BASE_URL, API_KEY, and MODEL for your endpoint.
# Works with Ollama, LM Studio, vLLM, LiteLLM, Together, Groq, etc.

# Required: Base URL of the OpenAI-compatible API
BASE_URL=http://localhost:11434/v1

# Optional: API key (defaults to 'none' if not set)
API_KEY=none

# Required: Model name to use
MODEL=llama3.2

# Optional: Set to 'true' if the model supports vision (screenshots)
# SUPPORTS_VISION=false

# ─── Edge Profile ─────────────────────────────────────────────────────────────
# Run `node scripts/setup.js` to auto-detect your profiles
# Or set manually:
EDGE_PROFILE_DIR=Profile 11
# (Profile 12 in Edge UI = "Profile 11" folder, Default = first profile)

# Custom Edge user data directory (leave blank for default Mac location)
# EDGE_USER_DATA_DIR=/Users/yourname/Library/Application Support/Microsoft Edge

# ─── Behavior ─────────────────────────────────────────────────────────────────
# Show browser window (true) or run headless (false)
HEADLESS=false

# Max steps the agent can take per task (safety limit)
MAX_AGENT_STEPS=50

# Highlight elements before interacting (visual feedback)
HIGHLIGHT_ELEMENTS=true
