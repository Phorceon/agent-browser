# ─── AI Provider Configuration ────────────────────────────────────────────────
# src/providers/index.js reads these three env vars:
#   BASE_URL  — OpenAI-compatible endpoint URL
#   API_KEY   — API key (use 'none' for local servers like Ollama)
#   MODEL     — Model name to use
#
# The optional AI_PROVIDER var is only used in index.js for display.

# ─── Quick Setup Examples (uncomment ONE block) ───────────────────────────────

# --- OpenAI ---
# BASE_URL=https://api.openai.com/v1
# API_KEY=sk-...
# MODEL=gpt-4o
# SUPPORTS_VISION=true

# --- Anthropic Claude (via OpenAI-compatible proxy, e.g. LiteLLM) ---
# BASE_URL=http://localhost:4000/v1
# API_KEY=sk-ant-...
# MODEL=claude-3-5-sonnet-20241022
# SUPPORTS_VISION=true

# --- Google Gemini (via OpenAI-compatible proxy, e.g. LiteLLM) ---
# BASE_URL=http://localhost:4000/v1
# API_KEY=AIza...
# MODEL=gemini-2.0-flash-exp
# SUPPORTS_VISION=true

# --- Ollama (local, no key needed) ---
BASE_URL=http://localhost:11434/v1
API_KEY=none
MODEL=llama3.2
SUPPORTS_VISION=false

# --- Custom endpoint (LM Studio, vLLM, etc.) ---
# BASE_URL=http://localhost:1234/v1
# API_KEY=lm-studio
# MODEL=local-model
# SUPPORTS_VISION=false

# ─── Active Provider (for display in TUI) ─────────────────────────────────────
# Options: openai | anthropic | gemini | ollama | custom
# Note: This is cosmetic — only BASE_URL/API_KEY/MODEL are used by the provider.
AI_PROVIDER=ollama

# ─── Edge Profile ─────────────────────────────────────────────────────────────
# Run `node scripts/setup.js` to auto-detect your profiles
# Or set manually:
EDGE_PROFILE_DIR=Profile 11
# (Profile 12 in Edge UI = "Profile 11" folder, Default = first profile)

# Custom Edge user data directory (leave blank for default Mac location)
# EDGE_USER_DATA_DIR=/Users/yourname/Library/Application Support/Microsoft Edge

# ─── Behavior ─────────────────────────────────────────────────────────────────
# Show browser window (true) or run headless (false)
HEADLESS=false

# Max steps the agent can take per task (safety limit)
MAX_AGENT_STEPS=50

# Highlight elements before interacting (visual feedback)
HIGHLIGHT_ELEMENTS=true
